# Copy to .env (git-ignored) and fill in — NEVER commit real keys.
#   cp .env.example .env && nano .env
#
# Master key the router requires on every client request
# (Authorization: Bearer <key>). Convention: start it with "sk-".
# Open WebUI reuses this as its key to the router (compose interpolates it).
LITELLM_MASTER_KEY=CHANGE_ME

# Cloud overflow tier — Anthropic API key (https://console.anthropic.com/).
# Only used when a local backend is down/unreachable (see config.yaml fallbacks).
# Leave as CHANGE_ME to run local-only; calls that fall through to cloud-overflow
# will then fail closed instead of leaving your network.
ANTHROPIC_API_KEY=CHANGE_ME

# ── LangGraph supervisor (langgraph-router/) — all OPTIONAL, sane defaults in code ──
# The model that PLANS/INTEGRATES. Default local-first (local-smart = qwen2.5:7b on the
# t630). Switch to cloud-explore for harder planning. NOTE: the t630 is 4-core / 16 GB —
# it CANNOT host a 27B/32B brain; a big supervisor belongs on cloud or the rented GPU.
SUPERVISOR_TIER=local-smart

# Read-only, fine-grained GitHub PAT for repo grounding (tools.py). Leave blank to skip
# grounding entirely. NEVER commit a real token.
GITHUB_TOKEN=

# Privacy: any GitHub grounding context forces LOCAL-ONLY routing by default (private
# repo content must not leak to a cloud model). Set to 1 ONLY when the source is public.
GITHUB_CONTEXT_ALLOW_CLOUD=0

# SQLite path for resumable multi-step runs (resume by thread_id). Blank = stateless.
LLM_ROUTER_CHECKPOINT=

# Hard cap on planned steps — runaway protection for the LLM-planned loop.
LLM_ROUTER_MAX_STEPS=6
