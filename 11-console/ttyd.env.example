# Copy to /etc/a777ance/ttyd.env (root-owned, chmod 600) and fill in. NEVER commit the real file.
#   sudo mkdir -p /etc/a777ance
#   sudo cp 11-console/ttyd.env.example /etc/a777ance/ttyd.env
#   sudo nano /etc/a777ance/ttyd.env && sudo chmod 600 /etc/a777ance/ttyd.env
#
# This file is read by ttyd-thinclient.service and ttyd-laptop.service.

# ttyd HTTP basic-auth credential, as user:password. This is the ONLY gate between the network
# and a shell on the box — treat it like a root password. Use a long, unique password.
TTYD_CRED=odin:CHANGE_ME

# The laptop SSH target the t630 jumps to, as user@host. Prefer a STABLE address: the laptop's
# WireGuard tunnel IP (10.8.0.x) or a DHCP-reserved LAN IP — not a floating DHCP lease.
LAPTOP_SSH=CHANGE_ME@10.8.0.CHANGE_ME
