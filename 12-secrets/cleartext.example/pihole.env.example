# Cleartext template for the Pi-hole admin secret (sealed → vault/pihole.env.sops).
#   cp cleartext.example/pihole.env.example cleartext/pihole.env
#   nano cleartext/pihole.env && ./seal.sh
#
# Decrypts on the box to ~/pihole/.env. To actually consume it, 02-pihole/docker-
# compose.yml must reference the variable instead of hard-coding the password:
#   environment:
#     FTLCONF_webserver_api_password: ${FTLCONF_webserver_api_password}
# and compose auto-loads ~/pihole/.env. Until that edit lands this file is inert —
# it is scaffolded here so the payload is complete. `rotate-secrets.sh apps` rerolls it.

# Pi-hole v6 web/API admin password (FTLCONF_webserver_api_password).
FTLCONF_webserver_api_password=CHANGE_ME
