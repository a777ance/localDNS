# Cleartext template for the LLM router secret (sealed → vault/llm-router.env.sops).
#   cp cleartext.example/llm-router.env.example cleartext/llm-router.env
#   nano cleartext/llm-router.env    # fill in real values
#   ./seal.sh                        # encrypt into vault/ (safe to commit)
#
# cleartext/ is git-ignored — the filled file must NEVER be committed. Only its
# sealed twin in vault/ goes into git. Decrypts on the box to ~/llm-router/.env.
#
# Mirrors the keys in 10-ai-orchestration/.env.example that carry SECRETS. The
# non-secret Odin/Loki/Frigg tuning knobs stay in that plaintext .env.example —
# only credentials are sealed here.

# Master key the router requires on every request (Authorization: Bearer <key>).
# Convention: start with "sk-". `rotate-secrets.sh apps` regenerates this.
LITELLM_MASTER_KEY=sk-CHANGE_ME

# Anthropic API key — the one with real spend attached (cloud-overflow tier).
ANTHROPIC_API_KEY=CHANGE_ME
