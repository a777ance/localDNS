# Cleartext template for the web-terminal credential (sealed → vault/ttyd.env.sops).
#   cp cleartext.example/ttyd.env.example cleartext/ttyd.env
#   nano cleartext/ttyd.env && ./seal.sh
#
# Decrypts on the box to /etc/a777ance/ttyd.env (read by ttyd-thinclient.service and
# ttyd-laptop.service). This is the ONLY gate between the network and a root-capable
# shell — treat it like a root password. `rotate-secrets.sh apps` rerolls TTYD_CRED.

# ttyd HTTP basic-auth, as user:password. Use a long, unique password.
TTYD_CRED=odin:CHANGE_ME

# Laptop SSH target the t630 jumps to (user@host). Prefer a STABLE address — the
# laptop's WireGuard IP (10.8.0.x) or a DHCP-reserved LAN IP. Not a secret, but it
# rides along in the same file. Not rotated.
LAPTOP_SSH=CHANGE_ME@10.8.0.CHANGE_ME
