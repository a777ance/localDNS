# Cleartext template for the WireGuard SERVER private key (sealed → vault/wg0-key.env.sops).
#   cp cleartext.example/wg0-key.env.example cleartext/wg0-key.env
#   nano cleartext/wg0-key.env && ./seal.sh
#
# This is the tunnel's identity — the one secret in 05-wireguard/wg0.conf that stays a
# placeholder (REPLACE_WITH_SERVER_PRIVATE_KEY) in git. unseal.sh renders the real
# wg0.conf by substituting this value into that placeholder (kind: wg-inject in the
# manifest), so the private key never sits in a committed file.
#
# Generate a fresh keypair with:  wg genkey | tee >(wg pubkey)
# (or let `rotate-secrets.sh wg-server` do it and print the new PUBLIC key for peers).

WG_SERVER_PRIVATE_KEY=CHANGE_ME
