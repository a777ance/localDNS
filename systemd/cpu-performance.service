# Deploys to: /etc/systemd/system/cpu-performance.service
# Reload: sudo systemctl daemon-reload && sudo systemctl enable --now cpu-performance

[Unit]
Description=Force CPU to performance governor
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'echo performance | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
