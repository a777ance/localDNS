[Unit]
Description=CAKE queue discipline (upload bufferbloat management)
After=network-online.target wg-quick@wg0.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/cake-setup.sh
ExecStop=/sbin/tc qdisc del dev enp1s0 root
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
